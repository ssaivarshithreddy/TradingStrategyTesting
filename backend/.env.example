# Server Config
PORT=5000
NODE_ENV=development

# Supabase Configurations
# Replace these with your actual Supabase Project API details
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key

# Market Ingestion Configuration
GOLD_TICKER=XAUUSD=X

# Ollama AI Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# WhatsApp Cloud API Configurations
WHATSAPP_TOKEN=your-whatsapp-bearer-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
WHATSAPP_RECIPIENT_NUMBER=your-whatsapp-recipient-phone-number
